# Firebase Configuration (optional — app works fully without these)
# Get these values from your Firebase Console: https://console.firebase.google.com
# Project Settings > General > Your apps > Web app > Firebase SDK snippet (Config)
# Without these, the app runs in local-only mode. Add them to enable cloud backup & sync.

FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_app_id

# Google OAuth (for Google Sign-In via Backup & Sync)
# Create a Web OAuth 2.0 Client in Google Cloud Console.
# PKCE is used for the token exchange — no client secret is needed on the client.
# Without this, users can still use email/password for backup, or skip backup entirely.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id
